{
  "name": "ghtun",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "postStartCommand": "bash /usr/local/bin/start-all.sh"
,
  "portsAttributes": {
    "443": {
      "label": "xray",
      "protocol": "http",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "admin-gui",
      "protocol": "http",
      "onAutoForward": "openBrowser"
    }
  },
  "forwardPorts": [443, 8080],
  "hostRequirements": {
    "cpus": 2
  }
}